{
  "name": "code-review-service",
  "version": "1.0.0",
  "private": true,
  "description": "Servico de code review automatizado para PRs com agentes especializados.",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@azure/ai-projects": "^2.1.0",
    "@azure/core-auth": "^1.10.1",
    "@azure/identity": "^4.13.1",
    "diff": "^9.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
