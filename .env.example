PORT=3000
LOG_LEVEL=info

# GitHub — PAT: leitura para diff; gravar comentario/review na PR exige Pull requests (write) e/ou Issues (write) em fine-grained, ou escopo repo (classic)
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# GitLab — token de API; GITLAB_BASE_URL para self-hosted (padrao: https://gitlab.com/api/v4)
GITLAB_TOKEN=
GITLAB_BASE_URL=https://gitlab.com/api/v4
GITLAB_WEBHOOK_SECRET=

# Bitbucket Cloud — usuario + app password (API); segredo do webhook (HMAC) para POST /webhooks/bitbucket
BITBUCKET_USERNAME=
BITBUCKET_APP_PASSWORD=
BITBUCKET_WEBHOOK_SECRET=

# Azure DevOps — PAT com Code (Read); AZURE_DEVOPS_WEBHOOK_SECRET opcional (temporario)
# org/projeto fallback se o webhook nao trouxer URL do repo
AZURE_DEVOPS_PAT=
AZURE_DEVOPS_WEBHOOK_SECRET=
AZURE_DEVOPS_ORGANIZATION=
AZURE_DEVOPS_PROJECT=

REVIEW_SERVICE_TOKEN=

# Local: true para ver a causa em JSON em caso de 500 (nao use em producao publica)
EXPOSE_REVIEW_ERROR_DETAIL=true

# Publicar comentario na PR/MR com o resumo do review (default ligado). false para desligar.
POST_REVIEW_PR_COMMENT=true

# Microsoft Foundry / Azure AI Projects (obrigatorio para o review)
# Substitua pelo endpoint do seu projeto no portal Azure AI Foundry.
AZURE_AI_PROJECT_ENDPOINT=https://SEU-RECURSO.services.ai.azure.com/api/projects/SEU-PROJETO
# Opcional: chave do recurso (local sem az login). Se vazio, usa DefaultAzureCredential.
AZURE_AI_PROJECT_API_KEY=
# Lista de agentes Foundry: use UM dos dois (nao ambos).
# Opcao A — ficheiro JSON (recomendado em K8s: ConfigMap montado). Caminho relativo ao cwd ao iniciar o processo.
FOUNDRY_AGENTS_CONFIG_PATH=./foundry-agents.example.json
# Opcao B — JSON inline (uma linha ou escapado). Ex.: [{"id":"docs","foundryName":"docs-cr","foundryVersion":"1"}]
# FOUNDRY_AGENTS_JSON=
