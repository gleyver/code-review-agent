PORT=3000
LOG_LEVEL=info

# GitHub — PAT: leitura para diff; gravar comentario/review na PR exige Pull requests (write) e/ou Issues (write) em fine-grained, ou escopo repo (classic)
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# GitLab — token de API; GITLAB_BASE_URL para self-hosted (padrao: https://gitlab.com/api/v4)
GITLAB_TOKEN=
GITLAB_BASE_URL=https://gitlab.com/api/v4
GITLAB_WEBHOOK_SECRET=

# Bitbucket Cloud — usuario + app password (ou password de app com escopo repositorio)
BITBUCKET_USERNAME=
BITBUCKET_APP_PASSWORD=

# Azure DevOps — PAT com Code (Read); org/projeto fallback se o webhook nao trouxer URL do repo
AZURE_DEVOPS_PAT=
AZURE_DEVOPS_WEBHOOK_SECRET=
AZURE_DEVOPS_ORGANIZATION=
AZURE_DEVOPS_PROJECT=

REVIEW_SERVICE_TOKEN=

# Local: true para ver a causa em JSON em caso de 500 (nao use em producao publica)
EXPOSE_REVIEW_ERROR_DETAIL=true

# Publicar comentario na PR/MR com o resumo do review (default ligado). false para desligar.
POST_REVIEW_PR_COMMENT=true

# LLM — OpenAI direto (prompts no codigo) OU agentes Microsoft Foundry (Azure AI Projects)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Microsoft Foundry / Azure AI Projects
# Opcional: AZURE_AI_PROJECT_API_KEY = chave do recurso (local sem az login). Se vazio, usa DefaultAzureCredential.
AZURE_AI_PROJECT_API_KEY=
# Agentes: performance-cr | security-cr | architecture-cr — ajuste VERSION ao da UI (ex. 1 ou 2)
AZURE_AI_PROJECT_ENDPOINT="https://ai-jornada-de-aprendizagem.services.ai.azure.com/api/projects/ai-jornada-de-aprendizagem"
FOUNDRY_AGENT_PERFORMANCE_NAME=performance-cr
FOUNDRY_AGENT_PERFORMANCE_VERSION=1
FOUNDRY_AGENT_SECURITY_NAME=security-cr
FOUNDRY_AGENT_SECURITY_VERSION=1
FOUNDRY_AGENT_ARCHITECTURE_NAME=architecture-cr
FOUNDRY_AGENT_ARCHITECTURE_VERSION=1
